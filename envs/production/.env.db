# Production PostgreSQL settings
MAKEPAD_POSTGRES_BIND_ADDRESS=0.0.0.0
MAKEPAD_POSTGRES_PORT=5432
MAKEPAD_POSTGRES_DATA_PATH=/var/lib/makepad/postgres
MAKEPAD_POSTGRES_BACKUP_PATH=/var/backups/makepad/postgres
MAKEPAD_POSTGRES_RETENTION_DAILY=30
MAKEPAD_POSTGRES_RETENTION_MONTHLY=12
MAKEPAD_POSTGRES_RESTIC_REPOSITORY=sftp:makepad-storagebox:catwlk/postgres
